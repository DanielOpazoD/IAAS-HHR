rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper functions
    // -------------------------------------------------------------------------

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return getUserRole() == 'admin';
    }

    /**
     * Año must be a realistic hospital year (2015-2035).
     * Note: we intentionally avoid `is int` because the Firestore JS SDK
     * can store JavaScript numbers as double (e.g. 2026 → 2026.0), which
     * would cause `is int` to return false even for valid whole-number years.
     * The range check is sufficient to prevent obviously bad values.
     */
    function validAnio() {
      return request.resource.data.anio >= 2015
        && request.resource.data.anio <= 2035;
    }

    function isValidRole(role) {
      return role == null || role == 'admin' || role == 'pabellon' || role == 'matronas';
    }

    // -------------------------------------------------------------------------
    // User profiles
    // -------------------------------------------------------------------------
    match /users/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow write: if isAuthenticated() && isAdmin()
        && isValidRole(request.resource.data.get('role', null));
      allow create: if isAuthenticated()
        && request.auth.uid == uid
        && (!('role' in request.resource.data) || request.resource.data.role == null);
    }

    // -------------------------------------------------------------------------
    // Clinical data — flat collections with anio field
    // The app uses collection(db, 'cirugias') with where('anio', '==', year)
    // -------------------------------------------------------------------------

    match /cirugias/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && validAnio()
        && (isAdmin() || getUserRole() == 'pabellon');
      allow update, delete: if isAuthenticated()
        && (isAdmin() || getUserRole() == 'pabellon');
    }

    match /dip/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && validAnio()
        && (isAdmin() || getUserRole() == 'pabellon');
      allow update, delete: if isAuthenticated()
        && (isAdmin() || getUserRole() == 'pabellon');
    }

    match /partos/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && validAnio()
        && (isAdmin() || getUserRole() == 'matronas');
      allow update, delete: if isAuthenticated()
        && (isAdmin() || getUserRole() == 'matronas');
    }

    match /arepi/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && validAnio() && isAdmin();
      allow update, delete: if isAuthenticated() && isAdmin();
    }

    match /registroIaas/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && validAnio() && isAdmin();
      allow update, delete: if isAuthenticated() && isAdmin();
    }

    match /consolidacion/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && validAnio() && isAdmin();
      allow update, delete: if isAuthenticated() && isAdmin();
    }

    // -------------------------------------------------------------------------
    // Deny all other paths
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
