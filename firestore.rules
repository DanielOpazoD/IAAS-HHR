rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper functions
    // -------------------------------------------------------------------------

    /** Only authenticated users can access the database */
    function isAuthenticated() {
      return request.auth != null;
    }

    /** Returns true if the requesting user's role document grants write access */
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    /** Admin can write to any collection */
    function isAdmin() {
      return getUserRole() == 'admin';
    }

    /** Año must be a realistic hospital year (2015-2035) */
    function validAnio(anio) {
      return anio is int && anio >= 2015 && anio <= 2035;
    }

    /** Valid user roles — null means pending approval */
    function isValidRole(role) {
      return role == null || role == 'admin' || role == 'pabellon' || role == 'matronas';
    }

    // -------------------------------------------------------------------------
    // User profiles — users can read their own; only admin can write
    // -------------------------------------------------------------------------
    match /users/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow write: if isAuthenticated() && isAdmin();
      // Allow creating own profile on first login.
      // role must be null (pending) — prevents self-granting admin on creation.
      allow create: if isAuthenticated()
        && request.auth.uid == uid
        && (!('role' in request.resource.data) || request.resource.data.role == null);
    }

    // -------------------------------------------------------------------------
    // Per-year subcollections: /cirugias/{anio}/records/{id}
    // -------------------------------------------------------------------------

    match /cirugias/{anio}/records/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
        && validAnio(int(anio))
        && (isAdmin() || getUserRole() == 'pabellon');
    }

    match /dip/{anio}/records/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
        && validAnio(int(anio))
        && (isAdmin() || getUserRole() == 'pabellon');
    }

    match /partos/{anio}/records/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
        && validAnio(int(anio))
        && (isAdmin() || getUserRole() == 'matronas');
    }

    match /arepi/{anio}/records/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
        && validAnio(int(anio))
        && isAdmin();
    }

    match /registroIaas/{anio}/records/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
        && validAnio(int(anio))
        && isAdmin();
    }

    match /consolidacion/{anio}/records/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
        && validAnio(int(anio))
        && isAdmin();
    }

    // -------------------------------------------------------------------------
    // Deny all other paths by default
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
