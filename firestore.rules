rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper functions
    // -------------------------------------------------------------------------

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return getUserRole() == 'admin';
    }

    /**
     * Año must be a realistic hospital year (2015-2035).
     * Note: we intentionally avoid `is int` because the Firestore JS SDK
     * can store JavaScript numbers as double (e.g. 2026 → 2026.0), which
     * would cause `is int` to return false even for valid whole-number years.
     * The range check is sufficient to prevent obviously bad values.
     */
    function validAnio() {
      return request.resource.data.anio >= 2015
        && request.resource.data.anio <= 2035;
    }

    function isValidRole(role) {
      return role == null || role == 'admin' || role == 'pabellon' || role == 'matronas';
    }

    // -------------------------------------------------------------------------
    // User profiles
    // -------------------------------------------------------------------------
    match /users/{uid} {
      // Single-document read: any user can read their own profile (no isAdmin() call)
      allow get: if isAuthenticated() && request.auth.uid == uid;
      // Collection query (list all users): only admins
      allow list: if isAuthenticated() && isAdmin();
      // Admin can update any profile (assign roles); users can update THEIR OWN non-role fields;
      // Bootstrap: a user can self-promote to admin if no bootstrap marker exists yet
      allow update: if isAuthenticated()
        && (
          (isAdmin() && isValidRole(request.resource.data.get('role', null)))
          || (request.auth.uid == uid
              && request.resource.data.role == resource.data.role)
          || (request.auth.uid == uid
              && request.resource.data.role == 'admin'
              && !exists(/databases/$(database)/documents/meta/adminBootstrapped))
        );
      // Only admin can delete profiles
      allow delete: if isAuthenticated() && isAdmin();
      // Any authenticated user can create their own profile on first login.
      // The profile can have role:'admin' ONLY if no admin document exists yet
      // (bootstrap mechanism for the very first user).
      allow create: if isAuthenticated()
        && request.auth.uid == uid
        && (
          (!('role' in request.resource.data) || request.resource.data.role == null)
          || (request.resource.data.role == 'admin'
              && !exists(/databases/$(database)/documents/meta/adminBootstrapped))
        );
    }

    // Meta document to track whether the initial admin has been bootstrapped.
    // Once created, no new users can self-assign admin via the create rule.
    match /meta/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && docId == 'adminBootstrapped'
        && request.auth.uid == request.resource.data.uid;
      allow update, delete: if false;
    }

    // -------------------------------------------------------------------------
    // Clinical data — flat collections with anio field
    // The app uses collection(db, 'cirugias') with where('anio', '==', year)
    // -------------------------------------------------------------------------

    match /cirugias/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && validAnio()
        && (isAdmin() || getUserRole() == 'pabellon');
      allow update, delete: if isAuthenticated()
        && (isAdmin() || getUserRole() == 'pabellon');
    }

    match /dip/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && validAnio()
        && (isAdmin() || getUserRole() == 'pabellon');
      allow update, delete: if isAuthenticated()
        && (isAdmin() || getUserRole() == 'pabellon');
    }

    match /partos/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && validAnio()
        && (isAdmin() || getUserRole() == 'matronas');
      allow update, delete: if isAuthenticated()
        && (isAdmin() || getUserRole() == 'matronas');
    }

    match /arepi/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && validAnio() && isAdmin();
      allow update, delete: if isAuthenticated() && isAdmin();
    }

    match /registroIaas/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && validAnio() && isAdmin();
      allow update, delete: if isAuthenticated() && isAdmin();
    }

    match /consolidacion/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && validAnio() && isAdmin();
      allow update, delete: if isAuthenticated() && isAdmin();
    }

    // -------------------------------------------------------------------------
    // Deny all other paths
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
